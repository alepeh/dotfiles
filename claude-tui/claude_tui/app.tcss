/* Claude TUI — main layout */

#main {
    height: 1fr;
}

/* ---- Sidebar ---- */

#sidebar {
    width: 42;
    min-width: 30;
    border-right: thick $primary;
}

#sidebar-header {
    text-style: bold;
    padding: 1;
    background: $primary;
    color: $text;
    text-align: center;
    height: 3;
}

#filter-input {
    margin: 0;
    border: none;
    background: $surface;
    padding: 0 1;
    height: 3;
    border-bottom: solid $primary-darken-2;
}

#filter-input:focus {
    border: none;
    border-bottom: solid $accent;
}

#session-list {
    height: 1fr;
}

HistoricSessionItem {
    padding: 0 1;
    height: auto;
    min-height: 3;
}

HistoricSessionItem:hover {
    background: $boost;
}

/* ---- Content area ---- */

#content {
    width: 1fr;
}

#content-header {
    padding: 1;
    background: $surface;
    border-bottom: solid $primary;
    height: auto;
    min-height: 3;
    max-height: 5;
}

#log {
    height: 1fr;
    padding: 0 1;
}

/* ---- Notifications ---- */

Toast {
    margin: 1 2;
}
